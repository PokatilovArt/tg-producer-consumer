{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../../..",
  "testRegex": "apps/producer/test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@app/contracts(|/.*)$": "<rootDir>/libs/contracts/src/$1",
    "^@app/rabbitmq(|/.*)$": "<rootDir>/libs/rabbitmq/src/$1"
  }
}
