# Producer
PRODUCER_PORT=3000

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=notifications.exchange
RABBITMQ_QUEUE=notifications.queue
RABBITMQ_ROUTING_KEY=notification.created
RABBITMQ_RETRY_TTL_MS=10000
RABBITMQ_MAX_RETRIES=5

# Redis (idempotency store)
REDIS_URL=redis://redis:6379
IDEMPOTENCY_TTL_SECONDS=86400

# Telegram
TELEGRAM_BOT_TOKEN=replace_with_real_bot_token
TELEGRAM_CHAT_ID=replace_with_chat_id

# Logging
LOG_LEVEL=info
