# Producer
PRODUCER_PORT=3000

# Postgres (outbox)
DATABASE_URL=postgres://finsol:finsol@postgres:5432/finsol
DATABASE_POOL_MAX=10
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=10

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_RETRY_TTL_MS=10000
RABBITMQ_MAX_RETRIES=5

# Redis (idempotency store)
REDIS_URL=redis://redis:6379
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_PENDING_TTL_SECONDS=60

# Telegram
TELEGRAM_BOT_TOKEN=replace_with_real_bot_token
TELEGRAM_CHAT_ID=replace_with_chat_id
# Optional: Markdown | MarkdownV2 | HTML. Omit for plain text.
# TELEGRAM_PARSE_MODE=MarkdownV2

# Logging
LOG_LEVEL=info
